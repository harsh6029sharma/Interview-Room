generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Role {
  INTERVIEWER
  CANDIDATE
  SYSTEM
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  NOT_STARTED
  IN_PROGRESS
  SOLVED
  SKIPPED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interviews Interview[]
}

model Interview {
  id          String          @id @default(cuid())
  title       String
  status      InterviewStatus @default(SCHEDULED)
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?

  candidateName  String?
  candidateEmail String?

  interviewerId String
  interviewer   User   @relation(fields: [interviewerId], references: [id])

  interviewQuestions InterviewQuestion[]
  chatMessages       ChatMessage[]
  aiSummary          AISummary?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id           String     @id @default(cuid())
  title        String
  description  String
  difficulty   Difficulty @default(MEDIUM)
  starterCode  Json
  testCases    Json
  functionName String

  interviewQuestions InterviewQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InterviewQuestion {
  id     String         @id @default(cuid())
  order  Int
  status QuestionStatus @default(NOT_STARTED)

  startedAt DateTime?
  endedAt   DateTime?

  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id])

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  codeSession CodeSession?
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([interviewId, questionId])
  @@unique([interviewId, order])
}

model CodeSession {
  id            String   @id @default(cuid())
  language      String
  currentCode   String   @default("")
  version       Int      @default(0)
  lastUpdatedAt DateTime @updatedAt

  interviewQuestionId String            @unique
  interviewQuestion   InterviewQuestion @relation(fields: [interviewQuestionId], references: [id])

  createdAt DateTime @default(now())
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderRole Role
  senderName String?
  message    String
  sentAt     DateTime @default(now())

  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id])

  createdAt DateTime @default(now())
}

model Submission {
  id            String   @id @default(cuid())
  language      String
  code          String
  testResults   Json
  passCount     Int
  totalCount    Int
  executionTime Int?
  memoryUsed    Int?
  submittedAt   DateTime @default(now())

  interviewQuestionId String
  interviewQuestion   InterviewQuestion @relation(fields: [interviewQuestionId], references: [id])

  createdAt DateTime @default(now())
}

model AISummary {
  id             String @id @default(cuid())
  summaryText    String
  strengths      Json
  weaknesses     Json
  recommendation String

  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
